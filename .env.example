# Required for API calls.
TIKTOK_ACCESS_TOKEN=your_access_token

# Optional defaults.
TIKTOK_ADVERTISER_ID=your_advertiser_id
TIKTOK_API_BASE_URL=https://business-api.tiktok.com

# Mutations are disabled unless this is set to "live".
# Even then, write tools and CLI commands default to dry-run unless you pass dry_run=false / --live.
TIKTOK_MUTATION_MODE=dry_run

# Optional request tuning.
TIKTOK_TIMEOUT_SECONDS=30
